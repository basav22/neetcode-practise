{
    "name": "Python Development Container",
    "image": "mcr.microsoft.com/vscode/devcontainers/python:3",
    "features": {
        "python": "latest"
    },
    "settings": {
        "python.pythonPath": "/usr/local/bin/python"
    },
    "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
    ],
    "postCreateCommand": "pip install --upgrade pip"
}